@model MyStadiumStats.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var matchTypeLabels = System.Text.Json.JsonSerializer.Serialize(Model.MatchesByType.Keys.ToList());
    var matchTypeCounts = System.Text.Json.JsonSerializer.Serialize(Model.MatchesByType.Values.ToList());
    var scorerNames = System.Text.Json.JsonSerializer.Serialize(Model.TopScorers.Select(s => s.PlayerName).ToList());
    var scorerGoals = System.Text.Json.JsonSerializer.Serialize(Model.TopScorers.Select(s => s.TotalGoals).ToList());
    var scorerNamesTeam = System.Text.Json.JsonSerializer.Serialize(Model.TopScorersForMyTeam.Select(s => s.PlayerName).ToList());
    var scorerGoalsTeam = System.Text.Json.JsonSerializer.Serialize(Model.TopScorersForMyTeam.Select(s => s.TotalGoals).ToList());
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0">📊 Dashboard</h2>
        @if (Model.MyTeam != null)
        {
            <span class="text-muted">Takımım: <strong class="text-primary">@Model.MyTeam.Name</strong></span>
        }
        else
        {
            <small class="text-warning">
                Henüz bir takım "Benim Takımım" olarak işaretlenmedi.
                <a asp-controller="Teams" asp-action="Index">Takımlar</a> sayfasından ayarlayabilirsiniz.
            </small>
        }
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Matches" asp-action="Create" class="btn btn-success btn-lg">+ Yeni Maç Ekle</a>
        <div class="dropdown">
            <button class="btn btn-outline-secondary btn-lg dropdown-toggle" type="button" id="settingsMenu" data-bs-toggle="dropdown" aria-expanded="false">
                ⚙️ Seçenekler
            </button>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="settingsMenu">
                <li>
                    <a class="dropdown-item text-danger" href="@Url.Action("ClearAllData")">
                        <strong>🗑️ Tüm Veriyi Sil...</strong>
                    </a>
                </li>
            </ul>
        </div>
    </div>
</div>

@if (Model.TotalMatches == 0)
{
    <div class="text-center py-5">
        <div class="display-1 text-muted">📊</div>
        <h3 class="text-muted mt-3">Henüz maç kaydedilmedi</h3>
        <p class="text-muted">İlk maçını ekleyerek istatistiklerini takip etmeye başla!</p>
        <a asp-controller="Matches" asp-action="Create" class="btn btn-primary btn-lg mt-2">İlk Maçı Ekle</a>
    </div>
}
else
{
    <!-- Stat Cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3 col-lg-2">
            <div class="card text-center border-0 shadow-sm h-100">
                <div class="card-body py-3">
                    <div class="fs-1 fw-bold text-primary">@Model.TotalMatches</div>
                    <div class="text-muted small">Toplam Maç</div>
                </div>
            </div>
        </div>
        @if (Model.MyTeam != null)
        {
            <a asp-controller="Matches" asp-action="Index" asp-route-result="hw" class="col-6 col-md-3 col-lg-2 text-decoration-none">
                <div class="card text-center border-0 shadow-sm h-100 bg-success bg-opacity-10" style="cursor: pointer;">
                    <div class="card-body py-3">
                        <div class="fs-1 fw-bold text-success">@Model.HomeWins</div>
                        <div class="text-muted small">Ev Gal.</div>
                    </div>
                </div>
            </a>
            <a asp-controller="Matches" asp-action="Index" asp-route-result="aw" class="col-6 col-md-3 col-lg-2 text-decoration-none">
                <div class="card text-center border-0 shadow-sm h-100 bg-success bg-opacity-10" style="cursor: pointer;">
                    <div class="card-body py-3">
                        <div class="fs-1 fw-bold text-success">@Model.AwayWins</div>
                        <div class="text-muted small">Dep. Gal.</div>
                    </div>
                </div>
            </a>
            <a asp-controller="Matches" asp-action="Index" asp-route-result="hd" class="col-6 col-md-3 col-lg-2 text-decoration-none">
                <div class="card text-center border-0 shadow-sm h-100 bg-warning bg-opacity-10" style="cursor: pointer;">
                    <div class="card-body py-3">
                        <div class="fs-1 fw-bold text-warning">@Model.HomeDraws</div>
                        <div class="text-muted small">Ev Ber.</div>
                    </div>
                </div>
            </a>
            <a asp-controller="Matches" asp-action="Index" asp-route-result="ad" class="col-6 col-md-3 col-lg-2 text-decoration-none">
                <div class="card text-center border-0 shadow-sm h-100 bg-warning bg-opacity-10" style="cursor: pointer;">
                    <div class="card-body py-3">
                        <div class="fs-1 fw-bold text-warning">@Model.AwayDraws</div>
                        <div class="text-muted small">Dep. Ber.</div>
                    </div>
                </div>
            </a>
            <a asp-controller="Matches" asp-action="Index" asp-route-result="hl" class="col-6 col-md-3 col-lg-2 text-decoration-none">
                <div class="card text-center border-0 shadow-sm h-100 bg-danger bg-opacity-10" style="cursor: pointer;">
                    <div class="card-body py-3">
                        <div class="fs-1 fw-bold text-danger">@Model.HomeLosses</div>
                        <div class="text-muted small">Ev Mağl.</div>
                    </div>
                </div>
            </a>
            <a asp-controller="Matches" asp-action="Index" asp-route-result="al" class="col-6 col-md-3 col-lg-2 text-decoration-none">
                <div class="card text-center border-0 shadow-sm h-100 bg-danger bg-opacity-10" style="cursor: pointer;">
                    <div class="card-body py-3">
                        <div class="fs-1 fw-bold text-danger">@Model.AwayLosses</div>
                        <div class="text-muted small">Dep. Mağl.</div>
                    </div>
                </div>
            </a>
            <div class="col-6 col-md-3 col-lg-2">
                <div class="card text-center border-0 shadow-sm h-100">
                    <div class="card-body py-3">
                        <div class="fs-1 fw-bold">@Model.WinRate%</div>
                        <div class="text-muted small">Gal. Oranı</div>
                    </div>
                </div>
            </div>
        }
        <div class="col-6 col-md-3 col-lg-2">
            <div class="card text-center border-0 shadow-sm h-100">
                <div class="card-body py-3">
                    <div class="fs-1 fw-bold text-dark">@Model.TotalGoalsWitnessed</div>
                    <div class="text-muted small">İzlenen Gol</div>
                </div>
            </div>
        </div>
    </div>

    <!-- My Team Stats Table -->
    @if (Model.MyTeam != null)
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header fw-semibold">@Model.MyTeam.Name - Sonuç Detayları</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="text-center">Toplam Maç</th>
                                <th class="text-center">
                                    <a asp-controller="Matches" asp-action="Index" asp-route-result="hw" class="text-decoration-none text-success fw-bold" style="cursor: pointer;">
                                        Ev Gal.
                                    </a>
                                </th>
                                <th class="text-center">
                                    <a asp-controller="Matches" asp-action="Index" asp-route-result="aw" class="text-decoration-none text-success fw-bold" style="cursor: pointer;">
                                        Dep. Gal.
                                    </a>
                                </th>
                                <th class="text-center">
                                    <a asp-controller="Matches" asp-action="Index" asp-route-result="hd" class="text-decoration-none text-warning fw-bold" style="cursor: pointer;">
                                        Ev Ber.
                                    </a>
                                </th>
                                <th class="text-center">
                                    <a asp-controller="Matches" asp-action="Index" asp-route-result="ad" class="text-decoration-none text-warning fw-bold" style="cursor: pointer;">
                                        Dep. Ber.
                                    </a>
                                </th>
                                <th class="text-center">
                                    <a asp-controller="Matches" asp-action="Index" asp-route-result="hl" class="text-decoration-none text-danger fw-bold" style="cursor: pointer;">
                                        Ev Mağl.
                                    </a>
                                </th>
                                <th class="text-center">
                                    <a asp-controller="Matches" asp-action="Index" asp-route-result="al" class="text-decoration-none text-danger fw-bold" style="cursor: pointer;">
                                        Dep. Mağl.
                                    </a>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="text-center"><strong>@Model.TotalMatches</strong></td>
                                <td class="text-center"><strong>@Model.HomeWins</strong></td>
                                <td class="text-center"><strong>@Model.AwayWins</strong></td>
                                <td class="text-center"><strong>@Model.HomeDraws</strong></td>
                                <td class="text-center"><strong>@Model.AwayDraws</strong></td>
                                <td class="text-center"><strong>@Model.HomeLosses</strong></td>
                                <td class="text-center"><strong>@Model.AwayLosses</strong></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- Charts Row -->
    <div class="row g-3 mb-4">
        @if (Model.MyTeam != null)
        {
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header fw-semibold">Sonuç Dağılımı</div>
                    <div class="card-body d-flex justify-content-center align-items-center">
                        <canvas id="resultChart" style="max-height:220px;"></canvas>
                    </div>
                </div>
            </div>
        }
        @if (Model.MatchesByType.Any())
        {
            <div class="col-md-@(Model.MyTeam != null ? "4" : "6")">
                <div class="card shadow-sm h-100">
                    <div class="card-header fw-semibold">Maç Türüne Göre Dağılım</div>
                    <div class="card-body d-flex justify-content-center align-items-center">
                        <canvas id="matchTypeChart" style="max-height:220px;"></canvas>
                    </div>
                </div>
            </div>
        }
        @if (Model.TopScorers.Any())
        {
            <div class="col-md-@(Model.MyTeam != null ? "4" : "6")">
                <div class="card shadow-sm h-100">
                    <div class="card-header fw-semibold">En Çok Gol Atanlar</div>
                    <div class="card-body">
                        <canvas id="scorersChart" style="max-height:500px;"></canvas>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Team Scorers Chart -->
    @if (Model.MyTeam != null && Model.TopScorersForMyTeam.Any())
    {
        <div class="row g-3 mb-4">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header fw-semibold">@Model.MyTeam.Name - En Çok Gol Atanlar</div>
                    <div class="card-body">
                        <canvas id="scorersChartTeam" style="max-height:500px;"></canvas>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Maç Türüne Göre Galibiyet/Mağlubiyet (My Team) -->
    @if (Model.MyTeam != null && Model.WinsAndLossesByType.Any())
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header fw-semibold">Maç Türüne Göre Sonuçlar</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Maç Türü</th>
                                <th class="text-center">Toplam</th>
                                <th class="text-center">
                                    <span class="badge bg-success">Galibiyet</span>
                                </th>
                                <th class="text-center">
                                    <span class="badge bg-warning text-dark">Beraberlik</span>
                                </th>
                                <th class="text-center">
                                    <span class="badge bg-danger">Mağlubiyet</span>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var stat in Model.WinsAndLossesByType.OrderBy(x => x.Key))
                            {
                                <tr>
                                    <td>
                                        <strong>@stat.Key</strong>
                                    </td>
                                    <td class="text-center">
                                        <a asp-controller="Matches" asp-action="Index" asp-route-matchType="@stat.Key" class="text-decoration-none">
                                            <span class="badge bg-info" style="cursor:pointer;">@stat.Value.TotalMatches</span>
                                        </a>
                                    </td>
                                    <td class="text-center">
                                        <a asp-controller="Matches" asp-action="Index" asp-route-matchType="@stat.Key" asp-route-result="hw" class="text-decoration-none">
                                            <span class="badge bg-success" style="cursor:pointer;">@stat.Value.Wins</span>
                                        </a>
                                    </td>
                                    <td class="text-center">
                                        <a asp-controller="Matches" asp-action="Index" asp-route-matchType="@stat.Key" asp-route-result="hd" class="text-decoration-none">
                                            <span class="badge bg-warning text-dark" style="cursor:pointer;">@stat.Value.Draws</span>
                                        </a>
                                    </td>
                                    <td class="text-center">
                                        <a asp-controller="Matches" asp-action="Index" asp-route-matchType="@stat.Key" asp-route-result="hl" class="text-decoration-none">
                                            <span class="badge bg-danger" style="cursor:pointer;">@stat.Value.Losses</span>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- Takip Edilen Takımlar -->
    @if (Model.FollowedTeams.Any())
    {
        <div class="mb-4">
            <h4 class="mb-3">📌 Takip Ettiğim Takımlar</h4>
            <div class="row g-3">
                @foreach (var teamStat in Model.FollowedTeams)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="card shadow-sm h-100">
                            <div class="card-header fw-semibold">@teamStat.Team.Name</div>
                            <div class="card-body">
                                <div class="row g-2 text-center mb-3">
                                    <div class="col-4">
                                        <div class="text-success fw-bold">@teamStat.Wins</div>
                                        <small class="text-muted">Galibiyet</small>
                                    </div>
                                    <div class="col-4">
                                        <div class="text-warning fw-bold">@teamStat.Draws</div>
                                        <small class="text-muted">Beraberlik</small>
                                    </div>
                                    <div class="col-4">
                                        <div class="text-danger fw-bold">@teamStat.Losses</div>
                                        <small class="text-muted">Mağlubiyet</small>
                                    </div>
                                </div>
                                <div class="text-muted small">
                                    <strong>@teamStat.TotalMatches maç</strong>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Stadyuma Göre Sonuçlar (My Team) -->
    @if (Model.MyTeam != null && Model.StatsByStadium.Any())
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header fw-semibold">Stadyuma Göre Sonuçlar</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Stadyum</th>
                                <th class="text-center">Toplam</th>
                                <th class="text-center">
                                    <span class="badge bg-success">Galibiyet</span>
                                </th>
                                <th class="text-center">
                                    <span class="badge bg-warning text-dark">Beraberlik</span>
                                </th>
                                <th class="text-center">
                                    <span class="badge bg-danger">Mağlubiyet</span>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var stadium in Model.StatsByStadium.OrderBy(x => x.Key))
                            {
                                <tr>
                                    <td>
                                        <strong>@stadium.Key</strong>
                                    </td>
                                    <td class="text-center">
                                        <a asp-controller="Matches" asp-action="Index" asp-route-stadium="@stadium.Key" class="text-decoration-none">
                                            <span class="badge bg-info" style="cursor:pointer;">@stadium.Value.TotalMatches</span>
                                        </a>
                                    </td>
                                    <td class="text-center">
                                        <a asp-controller="Matches" asp-action="Index" asp-route-stadium="@stadium.Key" asp-route-result="win" class="text-decoration-none">
                                            <span class="badge bg-success" style="cursor:pointer;">@stadium.Value.Wins</span>
                                        </a>
                                    </td>
                                    <td class="text-center">
                                        <a asp-controller="Matches" asp-action="Index" asp-route-stadium="@stadium.Key" asp-route-result="draw" class="text-decoration-none">
                                            <span class="badge bg-warning text-dark" style="cursor:pointer;">@stadium.Value.Draws</span>
                                        </a>
                                    </td>
                                    <td class="text-center">
                                        <a asp-controller="Matches" asp-action="Index" asp-route-stadium="@stadium.Key" asp-route-result="loss" class="text-decoration-none">
                                            <span class="badge bg-danger" style="cursor:pointer;">@stadium.Value.Losses</span>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- Son Maçlar -->
    <div class="card shadow-sm mb-4">
        <div class="card-header d-flex justify-content-between align-items-center fw-semibold">
            <span>Son Maçlar</span>
            <a asp-controller="Matches" asp-action="Index" class="btn btn-sm btn-outline-primary">Tümünü Gör</a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Tarih</th>
                            <th>Maç</th>
                            <th class="text-center">Skor</th>
                            <th>Stadyum</th>
                            <th>Tür</th>
                            <th>Sonuç</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in Model.RecentMatches)
                        {
                            string resultClass = "text-muted";
                            string resultText;
                            if (Model.MyTeam != null &&
                                (m.HomeTeamId == Model.MyTeam.Id || m.AwayTeamId == Model.MyTeam.Id))
                            {
                                bool myHome = m.HomeTeamId == Model.MyTeam.Id;
                                bool win = myHome ? m.HomeScore > m.AwayScore : m.AwayScore > m.HomeScore;
                                bool draw = m.HomeScore == m.AwayScore;
                                resultClass = win ? "text-success fw-bold" : draw ? "text-warning fw-bold" : "text-danger fw-bold";
                                resultText = win ? "GALİBİYET" : draw ? "BERABERLİK" : "MAĞLUBİYET";
                            }
                            else
                            {
                                resultText = m.HomeScore > m.AwayScore ? $"{m.HomeTeam.Name} Kazandı" :
                                             m.AwayScore > m.HomeScore ? $"{m.AwayTeam.Name} Kazandı" : "Beraberlik";
                            }
                            <tr>
                                <td>@m.Date.ToString("dd.MM.yyyy")</td>
                                <td><strong>@m.HomeTeam.Name</strong> <span class="text-muted">vs</span> <strong>@m.AwayTeam.Name</strong></td>
                                <td class="text-center"><span class="badge bg-dark fs-6 px-3">@m.HomeScore - @m.AwayScore</span></td>
                                <td class="text-muted small">@m.Stadium.Name</td>
                                <td><span class="badge bg-secondary">@m.MatchType</span></td>
                                <td class="@resultClass">@resultText</td>
                                <td>
                                    <a asp-controller="Matches" asp-action="Details" asp-route-id="@m.Id"
                                       class="btn btn-sm btn-outline-secondary">Detay</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <style>
        .scorer-bar { height: 10px; border-radius: 4px; }
        .scorer-bar-danger  { background-color: #dc3545; }
        .scorer-bar-warning { background-color: #ffc107; }
        .scorer-bar-info    { background-color: #0dcaf0; }
        .scorer-bar-muted   { background-color: #6c757d; }
        tr.scorer-main { cursor: pointer; }
        tr.scorer-main:hover { background-color: rgba(0,0,0,.04); }
        tr.scorer-detail td { background-color: rgba(0,0,0,.02); font-size: .875rem; }
        body.dark-mode tr.scorer-detail td { background-color: rgba(255,255,255,.04); }
    </style>

    <!-- Golcü İstatistikleri -->
    @if (Model.TopScorers.Any() || Model.TopScorersForMyTeam.Any())
    {
        <div class="card shadow-sm">
            <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                <ul class="nav nav-tabs card-header-tabs" role="tablist" style="margin-bottom: 0;">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="scorers-all-tab" data-bs-toggle="tab" data-bs-target="#scorers-all" type="button" role="tab" aria-controls="scorers-all" aria-selected="true">
                            Tüm Golcüler
                        </button>
                    </li>
                    @if (Model.MyTeam != null && Model.TopScorersForMyTeam.Any())
                    {
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="scorers-team-tab" data-bs-toggle="tab" data-bs-target="#scorers-team" type="button" role="tab" aria-controls="scorers-team" aria-selected="false">
                                @Model.MyTeam.Name Golcüleri
                            </button>
                        </li>
                    }
                </ul>
                <a id="scorers-view-all-link" asp-controller="Players" asp-action="Statistics" class="btn btn-sm btn-outline-primary">Tümünü Gör</a>
            </div>
            <div class="card-body tab-content">
                <!-- All Scorers -->
                <div class="tab-pane fade show active" id="scorers-all" role="tabpanel" aria-labelledby="scorers-all-tab">
                    @if (Model.TopScorers.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width:40px;">#</th>
                                        <th>Oyuncu</th>
                                        <th class="text-center">Takım</th>
                                        <th class="text-center">Toplam Gol</th>
                                        <th class="text-center">Penaltı</th>
                                        <th class="text-center">Maç Başı Ort.</th>
                                        <th class="text-center" style="min-width:160px;">Tüm Gollerdeki Pay</th>
                                        <th style="width:30px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < Model.TopScorers.Count; i++)
                                    {
                                        var scorer = Model.TopScorers[i];
                                        var collapseId = $"scorer-detail-all-{i}";
                                        var hasBreakdown = scorer.Breakdown.Count > 1 ||
                                            (scorer.Breakdown.Count == 1 && (scorer.Breakdown[0].TeamName != scorer.TeamName || scorer.Breakdown[0].JerseyNumber.HasValue));
                                        var pct = scorer.GoalPercentage;
                                        var barClass = pct >= 50 ? "scorer-bar-danger" : pct >= 25 ? "scorer-bar-warning" : pct >= 10 ? "scorer-bar-info" : "scorer-bar-muted";
                                        var pctCss = pct.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
                                        <tr class="scorer-main @(hasBreakdown ? "scorer-expandable" : "")" data-detail-target="@collapseId">
                                            <td class="text-muted">@(i + 1)</td>
                                            <td><strong>@scorer.PlayerName</strong></td>
                                            <td class="text-center"><span class="text-muted small">@(scorer.TeamName ?? "-")</span></td>
                                            <td class="text-center">
                                                <a asp-controller="Matches" asp-action="Index" asp-route-playerId="@scorer.PlayerId" class="text-decoration-none">
                                                    <span class="badge bg-success fs-6 px-3" style="cursor:pointer;">@scorer.TotalGoals</span>
                                                </a>
                                            </td>
                                            <td class="text-center">
                                                @if (scorer.PenaltyGoals > 0)
                                                {
                                                    <a asp-controller="Matches" asp-action="Index" asp-route-playerId="@scorer.PlayerId" asp-route-isPenalty="true" class="text-decoration-none">
                                                        <span class="badge bg-warning text-dark" style="cursor:pointer;">@scorer.PenaltyGoals</span>
                                                    </a>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <span class="badge bg-secondary">@scorer.AvgGoalsPerMatch</span>
                                            </td>
                                            <td>
                                                <div class="d-flex align-items-center gap-2">
                                                    <div class="flex-grow-1 bg-light rounded" style="height:10px;">
                                                        <div class="scorer-bar @barClass" style="width:@pctCss%;"></div>
                                                    </div>
                                                    <small class="text-nowrap">@pct%</small>
                                                </div>
                                            </td>
                                            <td class="text-center text-muted small">
                                                @if (hasBreakdown) { <span class="chevron-icon">▼</span> }
                                            </td>
                                        </tr>
                                        @if (hasBreakdown)
                                        {
                                            <tr class="scorer-detail d-none" id="@collapseId">
                                                <td colspan="8" class="p-0">
                                                    <table class="table table-sm mb-0">
                                                        <thead>
                                                            <tr class="table-light">
                                                                <th style="width:40px;padding-left:2.5rem;"></th>
                                                                <th>Takım</th>
                                                                <th class="text-center">Forma No</th>
                                                                <th class="text-center">Gol</th>
                                                                <th class="text-center">Penaltı</th>
                                                                <th></th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var bd in scorer.Breakdown)
                                                            {
                                                                <tr>
                                                                    <td style="padding-left:2.5rem;"></td>
                                                                    <td class="text-muted">@(bd.TeamName ?? "-")</td>
                                                                    <td class="text-center">
                                                                        @if (bd.JerseyNumber.HasValue)
                                                                        {
                                                                            <span class="badge bg-secondary">#@bd.JerseyNumber</span>
                                                                        }
                                                                        else
                                                                        {
                                                                            <span class="text-muted">-</span>
                                                                        }
                                                                    </td>
                                                                    <td class="text-center"><span class="badge bg-success">@bd.Goals</span></td>
                                                                    <td class="text-center">
                                                                        @if (bd.PenaltyGoals > 0)
                                                                        {
                                                                            <span class="badge bg-warning text-dark">@bd.PenaltyGoals</span>
                                                                        }
                                                                        else
                                                                        {
                                                                            <span class="text-muted">-</span>
                                                                        }
                                                                    </td>
                                                                    <td></td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

                <!-- Team Scorers -->
                @if (Model.MyTeam != null && Model.TopScorersForMyTeam.Any())
                {
                    <div class="tab-pane fade" id="scorers-team" role="tabpanel" aria-labelledby="scorers-team-tab">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width:40px;">#</th>
                                        <th>Oyuncu</th>
                                        <th class="text-center">Toplam Gol</th>
                                        <th class="text-center">Penaltı</th>
                                        <th class="text-center">Maç Başı Ort.</th>
                                        <th class="text-center" style="min-width:160px;">Takımda Payı</th>
                                        <th style="width:30px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < Model.TopScorersForMyTeam.Count; i++)
                                    {
                                        var scorer = Model.TopScorersForMyTeam[i];
                                        var collapseId = $"scorer-detail-team-{i}";
                                        var hasBreakdown = scorer.Breakdown.Count > 1 ||
                                            (scorer.Breakdown.Count == 1 && (scorer.Breakdown[0].TeamName != scorer.TeamName || scorer.Breakdown[0].JerseyNumber.HasValue));
                                        var pct = Model.MyTeamTotalGoals > 0 ? (double)scorer.TotalGoals / Model.MyTeamTotalGoals * 100 : 0;
                                        var barClass = pct >= 50 ? "scorer-bar-danger" : pct >= 25 ? "scorer-bar-warning" : pct >= 10 ? "scorer-bar-info" : "scorer-bar-muted";
                                        var pctCss = pct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
                                        <tr class="scorer-main @(hasBreakdown ? "scorer-expandable" : "")" data-detail-target="@collapseId">
                                            <td class="text-muted">@(i + 1)</td>
                                            <td><strong>@scorer.PlayerName</strong> <span class="text-muted small">@(scorer.TeamName ?? "")</span></td>
                                            <td class="text-center">
                                                <a asp-controller="Matches" asp-action="Index" asp-route-playerId="@scorer.PlayerId" class="text-decoration-none">
                                                    <span class="badge bg-success fs-6 px-3" style="cursor:pointer;">@scorer.TotalGoals</span>
                                                </a>
                                            </td>
                                            <td class="text-center">
                                                @if (scorer.PenaltyGoals > 0)
                                                {
                                                    <a asp-controller="Matches" asp-action="Index" asp-route-playerId="@scorer.PlayerId" asp-route-isPenalty="true" class="text-decoration-none">
                                                        <span class="badge bg-warning text-dark" style="cursor:pointer;">@scorer.PenaltyGoals</span>
                                                    </a>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <span class="badge bg-secondary">@scorer.AvgGoalsPerMatch</span>
                                            </td>
                                            <td>
                                                <div class="d-flex align-items-center gap-2">
                                                    <div class="flex-grow-1 bg-light rounded" style="height:10px;">
                                                        <div class="scorer-bar @barClass" style="width:@pctCss%;"></div>
                                                    </div>
                                                    <small class="text-nowrap">@pct.ToString("F2")%</small>
                                                </div>
                                            </td>
                                            <td class="text-center text-muted small">
                                                @if (hasBreakdown) { <span class="chevron-icon">▼</span> }
                                            </td>
                                        </tr>
                                        @if (hasBreakdown)
                                        {
                                            <tr class="scorer-detail d-none" id="@collapseId">
                                                <td colspan="7" class="p-0">
                                                    <table class="table table-sm mb-0">
                                                        <thead>
                                                            <tr class="table-light">
                                                                <th style="width:40px;padding-left:2.5rem;"></th>
                                                                <th>Takım</th>
                                                                <th class="text-center">Forma No</th>
                                                                <th class="text-center">Gol</th>
                                                                <th class="text-center">Penaltı</th>
                                                                <th></th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var bd in scorer.Breakdown)
                                                            {
                                                                <tr>
                                                                    <td style="padding-left:2.5rem;"></td>
                                                                    <td class="text-muted">@(bd.TeamName ?? "-")</td>
                                                                    <td class="text-center">
                                                                        @if (bd.JerseyNumber.HasValue)
                                                                        {
                                                                            <span class="badge bg-secondary">#@bd.JerseyNumber</span>
                                                                        }
                                                                        else
                                                                        {
                                                                            <span class="text-muted">-</span>
                                                                        }
                                                                    </td>
                                                                    <td class="text-center"><span class="badge bg-success">@bd.Goals</span></td>
                                                                    <td class="text-center">
                                                                        @if (bd.PenaltyGoals > 0)
                                                                        {
                                                                            <span class="badge bg-warning text-dark">@bd.PenaltyGoals</span>
                                                                        }
                                                                        else
                                                                        {
                                                                            <span class="text-muted">-</span>
                                                                        }
                                                                    </td>
                                                                    <td></td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        // Golcü satırı toggle
        document.querySelectorAll('tr.scorer-expandable').forEach(function(tr) {
            tr.addEventListener('click', function() {
                var targetId = this.getAttribute('data-detail-target');
                var detailRow = document.getElementById(targetId);
                if (!detailRow) return;
                var isHidden = detailRow.classList.contains('d-none');
                detailRow.classList.toggle('d-none', !isHidden);
                var chevron = this.querySelector('.chevron-icon');
                if (chevron) chevron.textContent = isHidden ? '▲' : '▼';
            });
        });
        const chartColors = ['#4e73df','#1cc88a','#36b9cc','#f6c23e','#e74a3b','#858796','#fd7e14','#6610f2','#20c997','#e83e8c'];

        @if (Model.MyTeam != null && Model.TotalMatches > 0)
        {
            <text>
            new Chart(document.getElementById('resultChart'), {
                type: 'doughnut',
                data: {
                    labels: ['Ev Gal.','Dep. Gal.','Ev Ber.','Dep. Ber.','Ev Mağl.','Dep. Mağl.','Diğer'],
                    datasets: [{
                        data: [@Model.HomeWins, @Model.AwayWins, @Model.HomeDraws, @Model.AwayDraws, @Model.HomeLosses, @Model.AwayLosses, @Model.OtherResults],
                        backgroundColor: ['#28a745','#20c997','#ffc107','#ffde59','#dc3545','#fa5252','#6c757d'],
                        borderWidth: 2
                    }]
                },
                options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
            });
            </text>
        }
        @if (Model.MatchesByType.Any())
        {
            <text>
            new Chart(document.getElementById('matchTypeChart'), {
                type: 'doughnut',
                data: {
                    labels: @Html.Raw(matchTypeLabels),
                    datasets: [{
                        data: @Html.Raw(matchTypeCounts),
                        backgroundColor: chartColors,
                        borderWidth: 2
                    }]
                },
                options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
            });
            </text>
        }
        @if (Model.TopScorers.Any())
        {
            <text>
            new Chart(document.getElementById('scorersChart'), {
                type: 'bar',
                data: {
                    labels: @Html.Raw(scorerNames),
                    datasets: [{
                        label: 'Gol',
                        data: @Html.Raw(scorerGoals),
                        backgroundColor: '#4e73df',
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    indexAxis: 'y',
                    plugins: { legend: { display: false } },
                   scales: {
                            y: {
                                ticks: {
                                        autoSkip: false
                                        }
                                },
                            x: {
                                beginAtZero: true,
                                ticks: {
                                        stepSize: 1
                                        }
                                }
                            }
                }
            });
            </text>
        }
        @if (Model.TopScorersForMyTeam.Any())
        {
            <text>
            new Chart(document.getElementById('scorersChartTeam'), {
                type: 'bar',
                data: {
                    labels: @Html.Raw(scorerNamesTeam),
                    datasets: [{
                        label: 'Gol',
                        data: @Html.Raw(scorerGoalsTeam),
                        backgroundColor: '#1cc88a',
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    indexAxis: 'y',
                    plugins: { legend: { display: false } },
                   scales: {
                            y: {
                                ticks: {
                                        autoSkip: false
                                        }
                                },
                            x: {
                                beginAtZero: true,
                                ticks: {
                                        stepSize: 1
                                        }
                                }
                            }
                }
            });
            </text>
        }

        // Handle "Tümünü Gör" link based on active tab
        const scorersAllTab = document.getElementById('scorers-all-tab');
        const scorersTeamTab = document.getElementById('scorers-team-tab');
        const viewAllLink = document.getElementById('scorers-view-all-link');
        
        if (scorersAllTab && scorersTeamTab && viewAllLink) {
            function updateViewAllLink() {
                if (!scorersTeamTab.classList.contains('active')) {
                    // All scorers tab is active
                    viewAllLink.href = '/Players/Statistics';
                } else {
                    // Team scorers tab is active
                    viewAllLink.href = '/Players/Statistics?teamId=@Model.MyTeam?.Id';
                }
            }
            
            scorersAllTab.addEventListener('click', updateViewAllLink);
            scorersTeamTab.addEventListener('click', updateViewAllLink);
            updateViewAllLink(); // Initial state
        }
    </script>
}
