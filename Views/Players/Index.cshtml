@model IEnumerable<MyStadiumStats.Models.Player>
@{
    ViewData["Title"] = "Oyuncular";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Oyuncular</h2>
</div>

<p class="text-muted small">
    Oyuncular maç eklerken gol bilgisi girildiğinde otomatik olarak oluşturulur. Her maç için forma numarası ayrı saklanır.
</p>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <p class="text-muted">Henüz oyuncu eklenmedi. Maç ekleyerek gol girdikçe oyuncular otomatik oluşur.</p>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                            <th>Oyuncu</th>
                            <th>Takım</th>
                            <th class="text-center">Son Forma No</th>
                            <th class="text-center">Toplam Gol</th>
                        </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td><strong>@p.Name</strong></td>
                            <td class="text-muted">@(p.Team?.Name ?? "-")</td>
                            <td class="text-center">
                                @if (p.CurrentJerseyNumber.HasValue)
                                {
                                    <span class="badge bg-primary">#@p.CurrentJerseyNumber</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="text-center">
                                <span class="badge bg-success">@p.Goals.Count(g => !g.IsOwnGoal)</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
