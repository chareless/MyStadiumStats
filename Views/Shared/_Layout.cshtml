<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MyStadiumStats</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MyStadiumStats.styles.css" asp-append-version="true" />
    <style>
        :root {
            --bs-body-bg: #fff;
            --bs-body-color: #000;
            --bs-body-font-family: inherit;
        }
        
        body.dark-mode {
            --bs-body-bg: #1a1a1a;
            --bs-body-color: #e0e0e0;
            background-color: #1a1a1a;
            color: #e0e0e0;
        }
        
        body.dark-mode .navbar {
            background-color: #2d2d2d !important;
            border-bottom: 1px solid #444 !important;
        }
        
        body.dark-mode .navbar-light .navbar-brand,
        body.dark-mode .navbar-light .nav-link {
            color: #e0e0e0 !important;
        }
        
        body.dark-mode .card {
            background-color: #2d2d2d;
            border-color: #444;
            color: #e0e0e0;
        }
        
        body.dark-mode .card-header {
            background-color: #1a1a1a;
            border-color: #444;
            color: #e0e0e0;
        }
        
        body.dark-mode .table {
            color: #e0e0e0;
            border-color: #444;
        }
        
        body.dark-mode .table-light {
            background-color: #1a1a1a;
            color: #e0e0e0;
        }
        
        body.dark-mode .form-control,
        body.dark-mode .form-select {
            background-color: #2d2d2d;
            border-color: #444;
            color: #e0e0e0;
        }
        
        body.dark-mode .form-control::placeholder,
        body.dark-mode .form-select::placeholder {
            color: #999;
            opacity: 1;
        }
        
        body.dark-mode .form-control::-webkit-input-placeholder {
            color: #999;
        }
        
        body.dark-mode .form-control:-moz-placeholder {
            color: #999;
        }
        
        body.dark-mode .form-control::-moz-placeholder {
            color: #999;
        }
        
        body.dark-mode .form-control:-ms-input-placeholder {
            color: #999;
        }
        
        body.dark-mode datalist {
            background-color: #2d2d2d;
            color: #e0e0e0;
        }
        
        body.dark-mode datalist option {
            background-color: #2d2d2d;
            color: #e0e0e0;
        }
        
        body.dark-mode .dropdown-menu {
            background-color: #2d2d2d;
            border-color: #444;
        }
        
        body.dark-mode .dropdown-item {
            color: #e0e0e0;
        }
        
        body.dark-mode .dropdown-item:hover,
        body.dark-mode .dropdown-item:focus {
            background-color: #444;
            color: #e0e0e0;
        }
        
        body.dark-mode .text-muted {
            color: #999 !important;
        }
        
        body.dark-mode .btn-outline-secondary {
            color: #e0e0e0;
            border-color: #666;
        }
        
        body.dark-mode .btn-outline-secondary:hover {
            background-color: #666;
            color: #e0e0e0;
        }
        
        body.dark-mode h1,
        body.dark-mode h2,
        body.dark-mode h3,
        body.dark-mode h4,
        body.dark-mode h5,
        body.dark-mode h6 {
            color: #e0e0e0;
        }
        
        body.dark-mode .badge {
            background-color: #444;
            color: #e0e0e0;
        }
        
        body.dark-mode .alert {
            background-color: #2d2d2d;
            border-color: #444;
            color: #e0e0e0;
        }
        
        body.dark-mode .alert-danger {
            background-color: #3a2020;
            border-color: #663333;
            color: #ffcccc;
        }
        
        body.dark-mode .progress {
            background-color: #444;
        }
        
        body.dark-mode .breadcrumb {
            background-color: #2d2d2d;
            border-color: #444;
        }
        
        body.dark-mode .breadcrumb-item {
            color: #e0e0e0;
        }
        
        body.dark-mode .breadcrumb-item a {
            color: #6db3f2;
        }
        
        body.dark-mode .breadcrumb-item a:hover {
            color: #7fc3ff;
        }
        
        body.dark-mode .breadcrumb-item.active {
            color: #999;
        }
        
        body.dark-mode .table thead {
            background-color: #1a1a1a;
            color: #e0e0e0;
        }
        
        body.dark-mode .table-light {
            background-color: #1a1a1a;
            color: #e0e0e0;
        }
        
        body.dark-mode .table-light th {
            color: #e0e0e0;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">⚽ MyStadiumStats</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">📊 Dashboard</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" role="button" data-bs-toggle="dropdown">
                                ⚽ Maçlarım
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Matches" asp-action="Index">Tüm Maçlar</a></li>
                                <li><a class="dropdown-item" asp-controller="Matches" asp-action="Create">+ Yeni Maç Ekle</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" role="button" data-bs-toggle="dropdown">
                                ⚙️ Yönetim
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Teams" asp-action="Index">Takımlar</a></li>
                                <li><a class="dropdown-item" asp-controller="Players" asp-action="Index">Oyuncular</a></li>
                                <li><a class="dropdown-item" asp-controller="Coaches" asp-action="Index">Teknik Direktörler</a></li>
                                <li><a class="dropdown-item" asp-controller="Stadiums" asp-action="Index">Stadyumlar</a></li>
                            </ul>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center">
                        <button id="darkModeToggle" class="btn btn-sm btn-outline-secondary" title="Koyu tema">
                            🌙
                        </button>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - MyStadiumStats - <a asp-area="" asp-controller="Home" asp-action="Privacy">Gizlilik</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Dark Mode Toggle
        const darkModeToggle = document.getElementById('darkModeToggle');
        const isDarkMode = localStorage.getItem('darkMode') === 'true';
        
        if (isDarkMode) {
            document.body.classList.add('dark-mode');
            darkModeToggle.textContent = '☀️';
        }
        
        darkModeToggle.addEventListener('click', () => {
            document.body.classList.toggle('dark-mode');
            const isDark = document.body.classList.contains('dark-mode');
            localStorage.setItem('darkMode', isDark);
            darkModeToggle.textContent = isDark ? '☀️' : '🌙';
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
